<%- include('partials/header') %>

<%
function render_stars(rating) {
    const val = parseFloat(rating) || 0;
    const rounded = Math.round(val * 2) / 2; // round to nearest 0.5
    let output = '<div class="text-warning d-flex gap-1">';
    for (let i = 1; i <= 5; i++) {
        if (rounded >= i) {
            output += '<i class="fas fa-star"></i>';
        } else if (rounded >= i - 0.5) {
            output += '<i class="fas fa-star-half-alt"></i>';
        } else {
            output += '<i class="far fa-star"></i>';
        }
    }
    output += '</div>';
    return output;
}
%>

<div class="app-container">
    <%- include('partials/sidebar') %>
    
    <main class="main-content">
        <!-- Top Navigation -->
        <%- include('partials/top_nav') %>

        <!-- Page Header (matching layout header items) -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center bg-white p-3 rounded-4 shadow-sm border border-light mb-4 gap-3">
            <h2 class="h4 fw-bold mb-0 text-dark">Reports Center</h2>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <select class="form-select form-select-sm" style="width: auto;">
                    <option>Generate Donor</option>
                </select>
                <select class="form-select form-select-sm" style="width: auto;">
                    <option>Annual Engagement Summary</option>
                    <option>Monthly Engagement Summary</option>
                </select>
                <button onclick="window.print()" class="btn btn-primary btn-sm d-flex align-items-center gap-2">
                    <i class="fa-solid fa-file-pdf"></i> Export to PDF/Excel
                </button>
            </div>
        </div>

        <!-- Top Row Cards: Summary & Company Partnership Report -->
        <div class="row g-4 mb-4">
            <!-- Left Side: Monthly/Annual Summary Table & Bar Chart side-by-side -->
            <div class="col-lg-7">
                <div class="panel-card h-100 mb-0">
                    <div class="panel-card-header bg-light-subtle">
                        <h5 class="fw-bold mb-0 text-dark">Monthly/Annual Engagement Summary</h5>
                    </div>
                    <div class="panel-card-body">
                        <div class="row g-3">
                            <!-- Table -->
                            <div class="col-md-7">
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle m-0 text-xs text-secondary">
                                        <thead>
                                            <tr class="border-b text-muted text-uppercase text-xxs">
                                                <th class="pb-2 font-semibold">Type</th>
                                                <th class="pb-2 text-end">Visits</th>
                                                <th class="pb-2 text-end">Students</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y text-secondary">
                                            <tr>
                                                <td class="py-2 fw-medium text-dark">Visits by type</td>
                                                <td class="py-2 text-end">120</td>
                                                <td class="py-2 text-end">30</td>
                                            </tr>
                                            <% Object.keys(type_stats).forEach(type => { %>
                                                <tr>
                                                    <td class="py-2 fw-medium text-dark"><%= type %></td>
                                                    <td class="py-2 text-end"><%= type_stats[type].visits %></td>
                                                    <td class="py-2 text-end"><%= type_stats[type].students %></td>
                                                </tr>
                                            <% }) %>
                                            <tr class="fw-bold text-dark border-top">
                                                <td class="py-2">Top Companies</td>
                                                <td class="py-2 text-end">15</td>
                                                <td class="py-2 text-end">35</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            
                            <!-- Chart (matching Top Companies bar chart) -->
                            <div class="col-md-5 d-flex flex-column justify-content-between">
                                <div>
                                    <h6 class="text-xs font-semibold text-secondary text-uppercase tracking-wider mb-3 text-center">Top Companies</h6>
                                    <div class="relative" style="height: 160px; position: relative;">
                                        <canvas id="companiesChart"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Company Partnership Report table -->
            <div class="col-lg-5">
                <div class="panel-card h-100 mb-0">
                    <div class="panel-card-header bg-light-subtle">
                        <h5 class="fw-bold mb-0 text-dark">Company Partnership Report</h5>
                    </div>
                    <div class="panel-card-body p-0">
                        <div class="table-responsive">
                            <table class="table custom-table align-middle text-xs">
                                <thead>
                                    <tr>
                                        <th>Company</th>
                                        <th>Partnership</th>
                                        <th class="text-end">History</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% 
                                    const limitedCompanies = companies.slice(0, 5);
                                    limitedCompanies.forEach(c => { 
                                    %>
                                        <tr>
                                            <td><strong><%= c.name %></strong></td>
                                            <td class="text-muted">Detailed partnership...</td>
                                            <td class="text-end text-xxs text-secondary"><%= c.partnership_date.substring(5,7) %>.<%= c.partnership_date.substring(0,4) %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Row Cards: Student Feedback, Word Cloud & Export Feed -->
        <div class="panel-card mb-0">
            <div class="panel-card-body">
                <div class="row g-4 align-items-stretch">
                    <!-- Left: Average Ratings -->
                    <div class="col-lg-4">
                        <h5 class="fw-bold text-dark mb-3">Student Feedback Analytics</h5>
                        <h6 class="text-xs font-semibold text-secondary text-uppercase tracking-wider mb-3">Average ratings</h6>
                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="text-sm font-medium text-dark">Visits</span>
                                <%- render_stars(feedback.avg_visits) %>
                            </div>
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="text-sm font-medium text-dark">Learning Value</span>
                                <%- render_stars(feedback.avg_learning) %>
                            </div>
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="text-sm font-medium text-dark">Feedback</span>
                                <%- render_stars(feedback.avg_feedback) %>
                            </div>
                            <div class="text-xxs text-muted mt-2 border-top pt-2 text-center">
                                Compiled from <%= feedback.total_feedback %> submitted surveys.
                            </div>
                        </div>
                    </div>

                    <!-- Middle: Word Cloud Keywords -->
                    <div class="col-lg-4 border-start border-end">
                        <div class="d-flex flex-column justify-content-center h-100 px-3">
                            <h6 class="text-xs font-semibold text-secondary text-uppercase tracking-wider mb-3 text-center">Feedback Keywords</h6>
                            <div class="word-cloud-container py-4">
                                <span class="word-cloud-item text-primary fw-bold fs-4">learning</span>
                                <span class="word-cloud-item text-success fw-semibold fs-5">industry</span>
                                <span class="word-cloud-item text-warning fw-medium fs-6">knowledge</span>
                                <span class="word-cloud-item text-info fw-bold fs-5">practical</span>
                                <span class="word-cloud-item text-danger fw-semibold fs-6">skills</span>
                                <span class="word-cloud-item text-secondary fw-medium text-xs">exposure</span>
                                <span class="word-cloud-item text-primary fw-semibold fs-5">experience</span>
                                <span class="word-cloud-item text-success fw-bold fs-4">feedback</span>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Export logs & History Feed -->
                    <div class="col-lg-4 d-flex flex-column justify-content-between">
                        <button onclick="window.print()" class="btn btn-outline-primary btn-sm d-flex align-items-center justify-content-center gap-2 mb-3 align-self-end">
                            <i class="fa-solid fa-file-export"></i> Export to PDF/Excel
                        </button>
                        
                        <div class="space-y-3 d-flex flex-column gap-2 mt-auto">
                            <div class="d-flex align-items-center justify-content-between bg-light p-2 rounded-3 border" style="font-size: 0.8rem;">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="w-8 h-8 rounded-circle bg-primary-light text-primary d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                                        <i class="fa-solid fa-user text-xs"></i>
                                    </div>
                                    <span class="fw-semibold text-dark">Individual</span>
                                </div>
                                <span class="text-xxs text-muted">1 hour ago</span>
                            </div>
                            
                            <div class="d-flex align-items-center justify-content-between bg-light p-2 rounded-3 border" style="font-size: 0.8rem;">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="w-8 h-8 rounded-circle bg-info-light text-info d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                                        <i class="fa-solid fa-users text-xs"></i>
                                    </div>
                                    <span class="fw-semibold text-dark">Class</span>
                                </div>
                                <span class="text-xxs text-muted">2 hours ago</span>
                            </div>
                            
                            <div class="d-flex align-items-center justify-content-between bg-light p-2 rounded-3 border" style="font-size: 0.8rem;">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="w-8 h-8 rounded-circle bg-primary-light text-primary d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                                        <i class="fa-solid fa-user text-xs"></i>
                                    </div>
                                    <span class="fw-semibold text-dark">Individual</span>
                                </div>
                                <span class="text-xxs text-muted">1 day ago</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Chart Script for Reports -->
<script>
document.addEventListener("DOMContentLoaded", function() {
    const ctx = document.getElementById('companiesChart').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['May', 'Jun', 'Jul', 'Aug', 'Sep'],
            data: [12, 19, 15, 25, 22],
            datasets: [{
                label: 'Visits',
                data: [12, 19, 15, 25, 22],
                backgroundColor: '#3b82f6',
                borderRadius: 4,
                barPercentage: 0.6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { borderDash: [2, 4], color: '#f1f5f9' },
                    border: { display: false },
                    ticks: { font: { size: 9 }, color: '#94a3b8', stepSize: 10 }
                },
                x: {
                    grid: { display: false },
                    border: { display: false },
                    ticks: { font: { size: 9 }, color: '#94a3b8' }
                }
            }
        }
    });
});
</script>

<%- include('partials/footer') %>
