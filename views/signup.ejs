<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - AVTracker</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome 6 for modern icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 1.5rem;
        }
        
        .signup-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 2.5rem;
            max-width: 500px;
            width: 100%;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }
        
        .brand-logo {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #4f46e5 0%, #818cf8 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #fff;
            margin: 0 auto 1rem auto;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.4);
        }
        
        .form-control {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff !important;
            padding: 0.65rem 0.85rem;
            border-radius: 10px;
            transition: all 0.2s ease;
            font-size: 0.9rem;
        }
        
        .form-control:focus {
            background: rgba(255, 255, 255, 0.06);
            border-color: #818cf8;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.25);
            outline: none;
        }
        
        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }
        
        .form-label {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 0.35rem;
        }
        
        .btn-auth {
            background: linear-gradient(90deg, #4f46e5 0%, #6366f1 100%);
            border: none;
            color: #fff;
            font-weight: 600;
            padding: 0.75rem;
            border-radius: 10px;
            width: 100%;
            transition: all 0.2s ease;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
        }
        
        .btn-auth:hover {
            background: linear-gradient(90deg, #4338ca 0%, #4f46e5 100%);
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(79, 70, 229, 0.35);
        }
        
        .auth-footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.6);
        }
        
        .auth-footer a {
            color: #818cf8;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s ease;
        }
        
        .auth-footer a:hover {
            color: #a5b4fc;
        }

        .domain-badge {
            background: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            color: #34d399;
            font-size: 0.75rem;
            padding: 0.35rem 0.65rem;
            border-radius: 6px;
            display: inline-block;
            margin-top: 0.35rem;
            font-weight: 500;
        }
    </style>
</head>
<body>

    <div class="signup-card">
        <!-- Logo -->
        <div class="brand-logo">
            <i class="fa-solid fa-graduation-cap"></i>
        </div>
        
        <h3 class="text-center fw-bold text-white mb-1">Create Account</h3>
        <p class="text-center text-muted mb-4" style="font-size: 0.85rem;">Register a new Coordinator profile</p>
        
        <!-- Alerts -->
        <% if (error) { %>
            <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white text-xs d-flex align-items-center gap-2 mb-4" role="alert" style="font-size: 0.8rem;">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <div><%= error %></div>
            </div>
        <% } %>
        
        <!-- Form -->
        <form method="POST" action="/signup" onsubmit="return validateForm()">
            <div class="mb-3">
                <label for="fullName" class="form-label">Full Name</label>
                <input type="text" class="form-control" id="fullName" name="fullName" required placeholder="e.g. Dr. Ahmad Kamal">
            </div>
            
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input type="text" class="form-control" id="username" name="username" required placeholder="e.g. kamal_mmu">
            </div>
            
            <div class="mb-3">
                <label for="email" class="form-label">University Email Address</label>
                <input type="email" class="form-control" id="email" name="email" required placeholder="e.g. kamal@mmu.edu.my">
                <div class="domain-badge">
                    <i class="fa-solid fa-circle-info me-1"></i> Requires @mmu.edu.my email domain
                </div>
            </div>
            
            <div class="row g-2 mb-4">
                <div class="col-6">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password" name="password" required placeholder="••••••••">
                </div>
                <div class="col-6">
                    <label for="confirm_password" class="form-label">Confirm Password</label>
                    <input type="password" class="form-control" id="confirm_password" name="confirm_password" required placeholder="••••••••">
                </div>
            </div>
            
            <button type="submit" class="btn btn-auth mb-2">Create Account</button>
        </form>
        
        <!-- Redirect link -->
        <div class="auth-footer">
            Already have an account? <a href="/login">Sign In</a>
        </div>
    </div>

    <!-- Frontend validation check -->
    <script>
    function validateForm() {
        const email = document.getElementById('email').value.trim();
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirm_password').value;

        if (!email.toLowerCase().endsWith('@mmu.edu.my')) {
            alert("Error: Registration is restricted to Multimedia University emails ending with @mmu.edu.my.");
            return false;
        }

        if (password !== confirmPassword) {
            alert("Error: Passwords do not match.");
            return false;
        }

        return true;
    }
    </script>

</body>
</html>
