<%- include('partials/header') %>

<div class="app-container">
    <%- include('partials/sidebar') %>
    
    <main class="main-content">
        <!-- Top Navigation -->
        <%- include('partials/top_nav') %>

        <!-- Success Notifications -->
        <% if (success_param === 'approval_updated') { %>
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i> Approval pipeline stage updated successfully.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } else if (success_param === 'visit_logged') { %>
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i> New visit submitted to the pending approvals pipeline.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <div class="row g-4">
            <!-- Left Side: Pending Approvals list -->
            <div class="col-lg-5">
                <div class="panel-card mb-4">
                    <div class="panel-card-header bg-light-subtle">
                        <h5 class="mb-0 fw-bold">PENDING APPROVALS</h5>
                        <span class="badge bg-warning text-dark rounded-pill"><%= pending_visits.length %> Pending</span>
                    </div>
                    <div class="panel-card-body p-3" style="max-height: 600px; overflow-y: auto;">
                        <% if (pending_visits.length > 0) { %>
                            <div class="d-flex flex-column gap-3">
                                <% pending_visits.forEach(visit => { %>
                                    <% const isSelected = selected_visit && selected_visit.id === visit.id; %>
                                    <a href="/visits/approvals?id=<%= visit.id %>" class="text-decoration-none text-dark d-block">
                                        <div class="p-3 border rounded-3 transition-all <%= isSelected ? 'bg-primary-light border-primary shadow-sm' : 'bg-white border-light hover-bg-light' %>">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h6 class="fw-bold mb-0 text-truncate" style="max-width: 80%;"><%= visit.company_name %></h6>
                                                <span class="badge bg-warning text-dark text-xxs px-2 py-1"><%= visit.engagement_type %></span>
                                            </div>
                                            <div class="text-secondary text-xs mb-1">
                                                <i class="fa-solid fa-calendar me-1"></i> <%= visit.date_occurred %> | <i class="fa-solid fa-clock me-1"></i> <%= visit.start_time %> - <%= visit.end_time %>
                                            </div>
                                            <div class="text-secondary text-xs">
                                                <i class="fa-solid fa-user-tie me-1"></i> POC: <%= visit.contact_person %>
                                            </div>
                                            <div class="mt-2 d-flex gap-2">
                                                <span class="badge rounded-pill text-xxs <%= visit.approval_hod === 'Approved' ? 'bg-success text-white' : (visit.approval_hod === 'Rejected' ? 'bg-danger text-white' : 'bg-secondary text-white') %>">
                                                    HOD: <%= visit.approval_hod %>
                                                </span>
                                                <span class="badge rounded-pill text-xxs <%= visit.approval_industry === 'Approved' ? 'bg-success text-white' : (visit.approval_industry === 'Rejected' ? 'bg-danger text-white' : 'bg-secondary text-white') %>">
                                                    Ind: <%= visit.approval_industry %>
                                                </span>
                                            </div>
                                        </div>
                                    </a>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="text-center py-5 text-muted">
                                <i class="fa-solid fa-circle-check fs-2 text-success mb-2"></i>
                                <p class="mb-0">All visits are processed. No pending approvals!</p>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Processed History Widget -->
                <div class="panel-card">
                    <div class="panel-card-header">
                        <h6 class="mb-0 fw-bold">PROCESSED HISTORY</h6>
                    </div>
                    <div class="panel-card-body p-2" style="max-height: 250px; overflow-y: auto;">
                        <table class="table table-sm align-middle text-xs m-0">
                            <thead>
                                <tr>
                                    <th>Company</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% processed_visits.slice(0, 5).forEach(v => { %>
                                    <tr>
                                        <td><strong><%= v.company_name %></strong></td>
                                        <td><%= v.engagement_type %></td>
                                        <td>
                                            <span class="badge text-xxs <%= v.status === 'Completed' ? 'bg-success text-white' : (v.status === 'Scheduled' ? 'bg-info text-white' : 'bg-secondary text-white') %>">
                                                <%= v.status %>
                                            </span>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Right Side: Visit Approval Workflow flowchart -->
            <div class="col-lg-7">
                <% if (selected_visit) { %>
                    <div class="panel-card h-100">
                        <div class="panel-card-header bg-light-subtle">
                            <h5 class="mb-0 fw-bold">VISIT APPROVAL PIPELINE</h5>
                        </div>
                        <div class="panel-card-body">
                            <!-- Selected Visit Overview Details -->
                            <div class="bg-light p-3 rounded-3 mb-4 border border-light">
                                <h5 class="fw-bold mb-1"><%= selected_visit.company_name %></h5>
                                <div class="row g-2 mt-2 text-xs">
                                    <div class="col-md-6"><strong>Engagement Type:</strong> <%= selected_visit.engagement_type %></div>
                                    <div class="col-md-6"><strong>Date:</strong> <%= selected_visit.date_occurred %></div>
                                    <div class="col-md-6"><strong>Start/End Time:</strong> <%= selected_visit.start_time %> - <%= selected_visit.end_time %></div>
                                    <div class="col-md-6"><strong>Point of Contact:</strong> <%= selected_visit.contact_person %></div>
                                    <div class="col-md-6"><strong>Coordinator:</strong> <%= selected_visit.coordinator %></div>
                                    <div class="col-md-6"><strong>Nom Students:</strong> <%= selected_visit.students_count %></div>
                                    <div class="col-12 mt-2"><strong>Purpose/Agenda:</strong></div>
                                    <div class="col-12 text-secondary bg-white p-2 rounded border border-light text-xs"><%= selected_visit.objective || 'N/A' %></div>
                                    
                                    <div class="col-12 mt-2 d-flex gap-4 border-top pt-2">
                                        <div><i class="fa-solid <%= selected_visit.checklist_approved ? 'fa-square-check text-success' : 'fa-square text-muted' %> me-1"></i> Checklist approvals</div>
                                        <div><i class="fa-solid <%= selected_visit.required_approved ? 'fa-square-check text-success' : 'fa-square text-muted' %> me-1"></i> Required approvals</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Visual Step flowchart (matching Module 4 visual representation) -->
                            <div class="approval-flowchart ps-3">
                                
                                <!-- Step 1: Visit Submitted (Always completed) -->
                                <div class="d-flex align-items-start gap-4 position-relative">
                                    <div class="flowchart-circle bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; z-index: 10;">
                                        <i class="fa-solid fa-check"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0 text-success">[Visit Submitted]</h6>
                                        <p class="text-muted text-xxs mb-0">Visit was logged into system by coordinator</p>
                                    </div>
                                </div>

                                <!-- Step Line Connector -->
                                <div class="border-start border-success border-2 ms-3 my-2" style="height: 35px;"></div>

                                <!-- Step 2: HOD Approval -->
                                <div class="d-flex align-items-start gap-4 position-relative">
                                    <% 
                                    let hodColor = 'secondary';
                                    let hodIcon = 'fa-clock';
                                    if (selected_visit.approval_hod === 'Approved') { hodColor = 'success'; hodIcon = 'fa-check'; }
                                    else if (selected_visit.approval_hod === 'Rejected') { hodColor = 'danger'; hodIcon = 'fa-xmark'; }
                                    %>
                                    <div class="flowchart-circle bg-<%= hodColor %> text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; z-index: 10;">
                                        <i class="fa-solid <%= hodIcon %>"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="fw-bold mb-0 text-<%= hodColor %>">[HOD Approval]</h6>
                                                <p class="text-muted text-xxs mb-0">Academic Head of Department sign-off status: <strong><%= selected_visit.approval_hod %></strong></p>
                                            </div>
                                            <% if (selected_visit.approval_hod === 'Pending') { %>
                                                <div class="d-flex gap-1">
                                                    <form method="POST" action="/visits/approvals">
                                                        <input type="hidden" name="id" value="<%= selected_visit.id %>">
                                                        <input type="hidden" name="approval_type" value="hod">
                                                        <input type="hidden" name="approval_status" value="Approved">
                                                        <button type="submit" class="btn btn-success btn-xxs py-1 px-2 text-xxs">Approve</button>
                                                    </form>
                                                    <form method="POST" action="/visits/approvals">
                                                        <input type="hidden" name="id" value="<%= selected_visit.id %>">
                                                        <input type="hidden" name="approval_type" value="hod">
                                                        <input type="hidden" name="approval_status" value="Rejected">
                                                        <button type="submit" class="btn btn-danger btn-xxs py-1 px-2 text-xxs">Reject</button>
                                                    </form>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>

                                <!-- Step Line Connector -->
                                <div class="border-start border-<%= selected_visit.approval_hod === 'Approved' ? 'success' : 'secondary' %> border-2 ms-3 my-2" style="height: 35px;"></div>

                                <!-- Step 3: Industry Confirmation -->
                                <div class="d-flex align-items-start gap-4 position-relative">
                                    <% 
                                    let indColor = 'secondary';
                                    let indIcon = 'fa-clock';
                                    const isHodDone = selected_visit.approval_hod === 'Approved';
                                    if (selected_visit.approval_industry === 'Approved') { indColor = 'success'; indIcon = 'fa-check'; }
                                    else if (selected_visit.approval_industry === 'Rejected') { indColor = 'danger'; indIcon = 'fa-xmark'; }
                                    else if (!isHodDone) { indColor = 'light text-muted'; indIcon = 'fa-lock'; }
                                    %>
                                    <div class="flowchart-circle bg-<%= indColor %> text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; z-index: 10;">
                                        <i class="fa-solid <%= indIcon %>"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="fw-bold mb-0 text-<%= isHodDone ? indColor : 'muted' %>">[Industry Confirmation]</h6>
                                                <p class="text-muted text-xxs mb-0">Host employer site confirmation: <strong><%= selected_visit.approval_industry %></strong></p>
                                            </div>
                                            <% if (selected_visit.approval_industry === 'Pending' && isHodDone) { %>
                                                <div class="d-flex gap-1">
                                                    <form method="POST" action="/visits/approvals">
                                                        <input type="hidden" name="id" value="<%= selected_visit.id %>">
                                                        <input type="hidden" name="approval_type" value="industry">
                                                        <input type="hidden" name="approval_status" value="Approved">
                                                        <button type="submit" class="btn btn-success btn-xxs py-1 px-2 text-xxs">Approve</button>
                                                    </form>
                                                    <form method="POST" action="/visits/approvals">
                                                        <input type="hidden" name="id" value="<%= selected_visit.id %>">
                                                        <input type="hidden" name="approval_type" value="industry">
                                                        <input type="hidden" name="approval_status" value="Rejected">
                                                        <button type="submit" class="btn btn-danger btn-xxs py-1 px-2 text-xxs">Reject</button>
                                                    </form>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>

                                <!-- Step Line Connector -->
                                <div class="border-start border-<%= selected_visit.approval_industry === 'Approved' ? 'success' : 'secondary' %> border-2 ms-3 my-2" style="height: 35px;"></div>

                                <!-- Step 4: Scheduled (Promoted to Scheduled once both HOD & Industry are approved) -->
                                <div class="d-flex align-items-start gap-4 position-relative">
                                    <% 
                                    let schedColor = 'secondary';
                                    let schedIcon = 'fa-clock';
                                    const isIndDone = selected_visit.approval_industry === 'Approved';
                                    if (selected_visit.status === 'Scheduled' || selected_visit.status === 'Completed') { schedColor = 'success'; schedIcon = 'fa-calendar-check'; }
                                    else if (selected_visit.status === 'Cancelled') { schedColor = 'danger'; schedIcon = 'fa-xmark'; }
                                    else if (!isIndDone) { schedColor = 'light text-muted'; schedIcon = 'fa-lock'; }
                                    %>
                                    <div class="flowchart-circle bg-<%= schedColor %> text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; z-index: 10;">
                                        <i class="fa-solid <%= schedIcon %>"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="fw-bold mb-0 text-<%= isIndDone ? schedColor : 'muted' %>">[Scheduled / Completed]</h6>
                                                <p class="text-muted text-xxs mb-0">Visit active scheduled status: <strong><%= selected_visit.status %></strong></p>
                                            </div>
                                            
                                            <% if (selected_visit.status === 'Scheduled') { %>
                                                <div>
                                                    <form method="POST" action="/visits/approvals">
                                                        <input type="hidden" name="id" value="<%= selected_visit.id %>">
                                                        <input type="hidden" name="approval_type" value="status">
                                                        <input type="hidden" name="approval_status" value="Completed">
                                                        <button type="submit" class="btn btn-primary btn-xxs py-1 px-2 text-xxs"><i class="fa-solid fa-flag-checkered me-1"></i>Complete Visit</button>
                                                    </form>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="panel-card h-100 d-flex align-items-center justify-content-center">
                        <div class="text-center text-muted p-5">
                            <i class="fa-solid fa-circle-question fs-1 mb-2"></i>
                            <h5>No Visit Selected</h5>
                            <p class="text-xs">Click a pending visit from the left column to view and edit its approval status pipeline.</p>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
</div>

<%- include('partials/footer') %>
