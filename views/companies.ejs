<%- include('partials/header') %>

<div class="app-container">
    <%- include('partials/sidebar') %>
    
    <main class="main-content">
        <!-- Top Navigation -->
        <%- include('partials/top_nav') %>

        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="page-title-section mb-0">
                <h2>Company Profiles</h2>
                <p>Manage list of active, pending, and archived industry partner companies.</p>
            </div>
            <% if (user && user.role !== 'Admin') { %>
                <button class="btn btn-primary btn-sm" onclick="openAddModal()">
                    <i class="fa-solid fa-plus me-1"></i> Add Company
                </button>
            <% } %>
        </div>

        <!-- Alert Notification -->
        <% if (message) { %>
            <div class="alert alert-<%= message_type %> alert-dismissible fade show" role="alert">
                <%- message %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <!-- Search & Filter Card -->
        <div class="panel-card mb-4">
            <div class="panel-card-body py-3">
                <form method="GET" action="/companies" class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label text-xs fw-semibold text-secondary uppercase">Search Name</label>
                        <input type="text" name="search" class="form-control" placeholder="Search Company Name..." value="<%= search_query %>">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-xs fw-semibold text-secondary uppercase">Location Filter</label>
                        <select name="location" class="form-select">
                            <option value="">All Locations</option>
                            <% locations.forEach(loc => { %>
                                <option value="<%= loc %>" <%= location_filter === loc ? 'selected' : '' %>>
                                    <%= loc %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-xs fw-semibold text-secondary uppercase">Industry Filter</label>
                        <select name="industry" class="form-select">
                            <option value="">All Industries</option>
                            <% industries.forEach(ind => { %>
                                <option value="<%= ind %>" <%= industry_filter === ind ? 'selected' : '' %>>
                                    <%= ind %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fa-solid fa-filter me-1"></i> Filter
                            </button>
                            <% if (search_query || industry_filter || location_filter || include_archived) { %>
                                <a href="/companies" class="btn btn-outline-secondary w-50" title="Clear Filters">
                                    <i class="fa-solid fa-rotate-left"></i>
                                </a>
                            <% } %>
                            <% if (user && user.role === 'Admin') { %>
                                <a href="/companies?include_archived=<%= !include_archived %>" class="btn <%= include_archived ? 'btn-warning' : 'btn-outline-warning' %>" title="<%= include_archived ? 'Hide Archived' : 'Show Archived' %>" style="padding: 0.375rem 0.75rem;">
                                    <i class="fa-solid fa-box-archive"></i>
                                </a>
                            <% } %>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Companies Table -->
        <div class="panel-card">
            <div class="panel-card-header">
                <h5>Industry Partners List</h5>
                <span class="text-muted text-xs"><%= companies.length %> matching partners</span>
            </div>
            <div class="panel-card-body p-0">
                <div class="table-responsive">
                    <table class="table custom-table align-middle">
                        <thead>
                            <tr>
                                <th>Company Name</th>
                                <th>Industry</th>
                                <th>Location</th>
                                <th>Status</th>
                                <th>Last Engagement</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (companies.length > 0) { %>
                                <% companies.forEach(row => { %>
                                    <%
                                    let status_class = 'badge-pending';
                                    if (row.status === 'Active Partner') status_class = 'badge-completed';
                                    else if (row.status === 'Pending') status_class = 'badge-pending';
                                    else if (row.status === 'Archived' || row.status === 'Inactive') status_class = 'badge-cancelled';
                                    %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="avatar bg-light text-primary rounded border fw-bold text-uppercase d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                                    <%= row.name.substring(0, 2) %>
                                                </div>
                                                <div>
                                                    <span class="fw-bold text-dark"><%= row.name %></span>
                                                    <% if (row.contact_person) { %>
                                                        <div class="text-muted" style="font-size: 0.7rem;"><i class="fa-solid fa-user me-1"></i><%= row.contact_person %></div>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </td>
                                        <td><%= row.industry %></td>
                                        <td><i class="fa-solid fa-location-dot me-1 text-muted"></i> <%= row.location %></td>
                                        <td>
                                            <span class="badge-custom <%= status_class %>">
                                                <%= row.status %>
                                            </span>
                                        </td>
                                        <td>
                                            <span class="text-xs fw-semibold text-secondary">
                                                <%= row.last_engagement %>
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-1">
                                                <button class="btn btn-sm btn-light py-1 px-2 text-xs" onclick='openViewModal(<%= JSON.stringify(row) %>)'>
                                                    View
                                                </button>
                                                <% if (user && user.role !== 'Admin') { %>
                                                    <button class="btn btn-sm btn-light py-1 px-2 text-xs" onclick='openEditModal(<%= JSON.stringify(row) %>)'>
                                                        Edit
                                                    </button>
                                                    <a href="/add-visit?company_id=<%= row.id %>" class="btn btn-sm btn-primary py-1 px-2 text-xs" title="Add Engagement">
                                                        + Visit
                                                    </a>
                                                <% } %>
                                                <% if (user && user.role === 'Admin') { %>
                                                    <!-- Archive Form -->
                                                    <form method="POST" action="/companies/archive" class="d-inline m-0" onsubmit="return confirm('Are you sure you want to change this company\'s archiving status?')">
                                                        <input type="hidden" name="id" value="<%= row.id %>">
                                                        <button type="submit" class="btn btn-sm btn-outline-warning py-1 px-2 text-xs" title="Archive / Restore">
                                                            <i class="fa-solid fa-box-archive"></i>
                                                        </button>
                                                    </form>
                                                    <!-- Delete Form -->
                                                    <form method="POST" action="/companies/delete" class="d-inline m-0" onsubmit="return confirm('WARNING: Are you sure you want to permanently delete this company profile? This action will also delete all associated visit history!')">
                                                        <input type="hidden" name="id" value="<%= row.id %>">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2 text-xs" title="Delete Permanent">
                                                            <i class="fa-solid fa-trash-can"></i>
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No partners match the search criteria.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Add / Edit Company Modal -->
<div class="modal fade" id="companyModal" tabindex="-1" aria-labelledby="companyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="modal-title fw-bold" id="companyModalLabel">Add Industry Partner</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="POST" action="/companies" id="companyForm">
                <!-- Hidden input to store ID for edits -->
                <input type="hidden" name="id" id="company_id_input">
                
                <div class="modal-body px-4 pb-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="name" class="form-label text-xs fw-semibold text-secondary uppercase">Company Name *</label>
                            <input type="text" class="form-control" id="name" name="name" required placeholder="e.g. Microsoft Malaysia">
                        </div>
                        <div class="col-md-6">
                            <label for="industry" class="form-label text-xs fw-semibold text-secondary uppercase">Industry Area *</label>
                            <select class="form-select" id="industry" name="industry" required>
                                <option value="" disabled selected>Select Industry</option>
                                <option value="IT/Tech">IT / Tech / Software</option>
                                <option value="Automotive">Automotive</option>
                                <option value="Manufacturing">Manufacturing</option>
                                <option value="Energy">Energy & Utilities</option>
                                <option value="Finance">Finance & Banking</option>
                                <option value="Services">Professional Services</option>
                                <option value="Consultancy">Consultancy</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="location" class="form-label text-xs fw-semibold text-secondary uppercase">Location State/City *</label>
                            <input type="text" class="form-control" id="location" name="location" required placeholder="e.g. Selangor / Penang">
                        </div>
                        <div class="col-md-6">
                            <label for="partnership_date" class="form-label text-xs fw-semibold text-secondary uppercase">Partnership Start Date</label>
                            <input type="date" class="form-control" id="partnership_date" name="partnership_date" value="<%= new Date().toISOString().split('T')[0] %>">
                        </div>
                        
                        <!-- Contact Details Divider -->
                        <div class="col-12 mt-4 border-top pt-3">
                            <h6 class="fw-bold mb-2">Key Contact Information</h6>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="contact_person" class="form-label text-xs fw-semibold text-secondary uppercase">Contact Name</label>
                            <input type="text" class="form-control" id="contact_person" name="contact_person" placeholder="e.g. Ms. Jane Doe">
                        </div>
                        <div class="col-md-6">
                            <label for="email" class="form-label text-xs fw-semibold text-secondary uppercase">Contact Email</label>
                            <input type="email" class="form-control" id="email" name="email" placeholder="e.g. jane@company.com">
                        </div>
                        <div class="col-md-6">
                            <label for="phone" class="form-label text-xs fw-semibold text-secondary uppercase">Contact Phone</label>
                            <input type="text" class="form-control" id="phone" name="phone" placeholder="e.g. +6012-3456789">
                        </div>
                        <div class="col-md-6">
                            <label for="website" class="form-label text-xs fw-semibold text-secondary uppercase">Website URL</label>
                            <input type="url" class="form-control" id="website" name="website" placeholder="e.g. https://company.com">
                        </div>
                        
                        <div class="col-12">
                            <label for="status" class="form-label text-xs fw-semibold text-secondary uppercase">Partnership Status</label>
                            <select class="form-select" id="status" name="status">
                                <option value="Active Partner">Active Partner</option>
                                <option value="Pending">Pending</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="notes" class="form-label text-xs fw-semibold text-secondary uppercase">Internal Notes</label>
                            <textarea class="form-control" id="notes" name="notes" rows="3" placeholder="Add custom notes, collaboration scope, internship intake details..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 px-4 pb-4">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4" id="submitBtn">Save Company</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View Company Details Modal -->
<div class="modal fade" id="viewModal" tabindex="-1" aria-labelledby="viewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="modal-title fw-bold" id="viewModalLabel">Company Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 pb-4">
                <div class="d-flex align-items-center gap-3 mb-4 border-bottom pb-3">
                    <div class="avatar bg-primary-light text-primary rounded-circle border fw-bold text-uppercase d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; font-size: 1.2rem;" id="view_avatar">
                        TE
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0 text-dark" id="view_name">Company Name</h4>
                        <span class="badge bg-light text-secondary border mt-1" id="view_industry">IT/Tech</span>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <small class="text-muted d-block text-xxs uppercase fw-bold">Location</small>
                        <span id="view_location" class="fw-semibold">Selangor</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block text-xxs uppercase fw-bold">Status</small>
                        <span id="view_status" class="badge bg-success-light text-success">Active Partner</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block text-xxs uppercase fw-bold">Partnership Date</small>
                        <span id="view_partnership_date" class="fw-semibold">2023-10-15</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block text-xxs uppercase fw-bold">Last Engagement</small>
                        <span id="view_last_engagement" class="fw-semibold">N/A</span>
                    </div>

                    <div class="col-12 mt-3 border-top pt-3">
                        <h6 class="fw-bold text-dark">Contact Information</h6>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block text-xxs uppercase fw-bold">Key Contact</small>
                        <span id="view_contact_person" class="fw-semibold">N/A</span>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block text-xxs uppercase fw-bold">Phone Number</small>
                        <span id="view_phone" class="fw-semibold">N/A</span>
                    </div>
                    <div class="col-12">
                        <small class="text-muted d-block text-xxs uppercase fw-bold">Email Address</small>
                        <span id="view_email" class="fw-semibold">N/A</span>
                    </div>
                    <div class="col-12">
                        <small class="text-muted d-block text-xxs uppercase fw-bold">Website</small>
                        <a href="#" target="_blank" id="view_website" class="text-primary text-decoration-none fw-semibold">N/A</a>
                    </div>

                    <div class="col-12 mt-3 border-top pt-3">
                        <small class="text-muted d-block text-xxs uppercase fw-bold">Internal Notes</small>
                        <p id="view_notes" class="text-sm bg-light p-2 rounded mt-1 text-secondary" style="min-height: 50px;">No custom notes logged yet.</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0 px-4 pb-4">
                <button type="button" class="btn btn-primary w-100" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Controlling Script -->
<script>
let companyModal;
let viewModal;

document.addEventListener("DOMContentLoaded", function() {
    companyModal = new bootstrap.Modal(document.getElementById('companyModal'));
    viewModal = new bootstrap.Modal(document.getElementById('viewModal'));
});

function openAddModal() {
    document.getElementById('companyModalLabel').innerText = "Add Industry Partner";
    document.getElementById('company_id_input').value = "";
    document.getElementById('companyForm').reset();
    document.getElementById('submitBtn').innerText = "Save Company";
    
    // Set default date
    document.getElementById('partnership_date').value = new Date().toISOString().split('T')[0];
    
    companyModal.show();
}

function openEditModal(company) {
    document.getElementById('companyModalLabel').innerText = "Edit Industry Partner";
    document.getElementById('company_id_input').value = company.id;
    document.getElementById('name').value = company.name || "";
    document.getElementById('industry').value = company.industry || "";
    document.getElementById('location').value = company.location || "";
    document.getElementById('partnership_date').value = company.partnership_date || "";
    document.getElementById('contact_person').value = company.contact_person || "";
    document.getElementById('email').value = company.email || "";
    document.getElementById('phone').value = company.phone || "";
    document.getElementById('website').value = company.website || "";
    document.getElementById('status').value = company.status || "Active Partner";
    document.getElementById('notes').value = company.notes || "";
    
    document.getElementById('submitBtn').innerText = "Save Changes";
    companyModal.show();
}

function openViewModal(company) {
    document.getElementById('view_avatar').innerText = company.name.substring(0, 2);
    document.getElementById('view_name').innerText = company.name;
    document.getElementById('view_industry').innerText = company.industry;
    document.getElementById('view_location').innerText = company.location;
    document.getElementById('view_status').innerText = company.status;
    document.getElementById('view_status').className = `badge ${company.status === 'Active Partner' ? 'bg-success-light text-success' : (company.status === 'Pending' ? 'bg-warning-light text-warning' : 'bg-danger-light text-danger')}`;
    document.getElementById('view_partnership_date').innerText = company.partnership_date || 'N/A';
    document.getElementById('view_last_engagement').innerText = company.last_engagement || 'N/A';
    
    document.getElementById('view_contact_person').innerText = company.contact_person || 'N/A';
    document.getElementById('view_phone').innerText = company.phone || 'N/A';
    document.getElementById('view_email').innerText = company.email || 'N/A';
    
    const websiteEl = document.getElementById('view_website');
    if (company.website) {
        websiteEl.href = company.website;
        websiteEl.innerText = company.website;
        websiteEl.style.display = 'inline';
    } else {
        websiteEl.innerText = 'N/A';
        websiteEl.removeAttribute('href');
    }
    
    document.getElementById('view_notes').innerText = company.notes || 'No custom notes logged yet.';
    viewModal.show();
}
</script>

<%- include('partials/footer') %>
