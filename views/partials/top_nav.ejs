<!-- Top Navigation Bar -->
<div class="top-nav d-flex justify-content-between align-items-center mb-4 p-3 bg-white rounded-4 shadow-sm border border-light">
    <!-- Breadcrumbs / Section Indicator -->
    <div class="d-flex align-items-center gap-3">
        <div class="brand-small-icon bg-primary-light text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
            <i class="fa-solid fa-compass"></i>
        </div>
        <div class="top-nav-links d-flex align-items-center gap-4 me-auto">
            <a href="/" class="text-decoration-none fw-semibold text-secondary <%= current_page === 'index' ? 'text-primary border-bottom border-primary border-2 pb-1' : '' %>">
                <i class="fa-solid fa-chart-pie me-1"></i> Dashboard
            </a>
            <a href="/companies" class="text-decoration-none fw-semibold text-secondary <%= current_page === 'companies' ? 'text-primary border-bottom border-primary border-2 pb-1' : '' %>">
                <i class="fa-solid fa-building me-1"></i> Company Database
            </a>
            <a href="/visits/approvals" class="text-decoration-none fw-semibold text-secondary <%= current_page === 'visits' ? 'text-primary border-bottom border-primary border-2 pb-1' : '' %>">
                <i class="fa-solid fa-clipboard-check me-1"></i> Approvals
            </a>
            <a href="/reports" class="text-decoration-none fw-semibold text-secondary <%= current_page === 'reports' ? 'text-primary border-bottom border-primary border-2 pb-1' : '' %>">
                <i class="fa-solid fa-chart-line me-1"></i> Reports
            </a>
        </div>
    </div>

    <!-- Profile Action Dropdown / Details -->
    <div class="d-flex align-items-center gap-2">
        <div class="profile-badge d-flex align-items-center gap-2 bg-light p-1 pe-3 rounded-pill border">
            <% if (user) { %>
                <div class="profile-avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold text-uppercase" style="width: 32px; height: 32px; font-size: 0.85rem;">
                    <%= user.fullName.substring(0, 1) %>
                </div>
                <div class="text-start leading-none d-none d-sm-block">
                    <div class="fw-semibold text-dark text-xs" style="line-height: 1;"><%= user.fullName %></div>
                    <small class="text-muted text-xxs" style="font-size: 0.65rem;">@<%= user.username %></small>
                </div>
            <% } else { %>
                <div class="profile-avatar bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.85rem;">
                    G
                </div>
                <div class="text-start leading-none d-none d-sm-block">
                    <div class="fw-semibold text-dark text-xs" style="line-height: 1;">Guest</div>
                    <small class="text-muted text-xxs" style="font-size: 0.65rem;">Not Logged In</small>
                </div>
            <% } %>
        </div>
        
        <% if (user) { %>
            <a href="/logout" class="btn btn-outline-danger btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;" title="Log Out">
                <i class="fa-solid fa-power-off"></i>
            </a>
        <% } %>
    </div>
</div>
