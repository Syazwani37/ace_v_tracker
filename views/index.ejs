<%- include('partials/header') %>

<div class="app-container">
    <%- include('partials/sidebar') %>
    
    <main class="main-content">
        <!-- Top Nav Bar Inclusion -->
        <%- include('partials/top_nav') %>

        <!-- Page Welcome & Actions Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="page-title-section mb-0">
                <h2>Quick Stats</h2>
                <p>Employer engagements and industrial visit monitoring overview.</p>
            </div>
            <div>
                <a href="/export" class="btn btn-outline-secondary btn-sm me-2">
                    <i class="fa-solid fa-file-csv me-1"></i> Export CSV
                </a>
                <% if (user && user.role !== 'Admin') { %>
                    <a href="/add-visit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-plus me-1"></i> Log Visit
                    </a>
                <% } %>
            </div>
        </div>

        <!-- Success Notifications -->
        <% if (success_param === 'visit_logged') { %>
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i> Visit logged successfully. It has been sent to the approvals pipeline.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <!-- New User Approvals Alert for Administrators -->
        <% if (user && user.role === 'Admin' && pendingUsersCount > 0) { %>
            <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center justify-content-between p-3 mb-4 rounded-4" role="alert" style="background: rgba(245, 158, 11, 0.08); border: 1px solid rgba(245, 158, 11, 0.2) !important;">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-warning text-white d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
                        <i class="fa-solid fa-bell fs-5"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold text-dark mb-0">Pending User Registrations</h6>
                        <span class="text-secondary text-xs">There are <%= pendingUsersCount %> new accounts awaiting your activation approval.</span>
                    </div>
                </div>
                <a href="/admin/users" class="btn btn-warning btn-sm fw-semibold text-dark text-xs px-3 rounded-pill shadow-sm">
                    Review Now
                </a>
            </div>
        <% } %>

        <!-- Metrics Row (Matching mockup values: 120, 8, 550) -->
        <div class="row g-4 mb-4">
            <div class="col-md-4 stat-card-wrapper">
                <div class="stat-card">
                    <div class="stat-icon primary">
                        <i class="fa-solid fa-calendar-check"></i>
                    </div>
                    <div class="stat-card-info">
                        <h6>Total Engagements</h6>
                        <h2><%= total_engagements %></h2>
                        <span class="text-xxs text-muted"><i class="fa-solid fa-circle-info"></i> 16 Engagements logged</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4 stat-card-wrapper">
                <div class="stat-card">
                    <div class="stat-icon success">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                    </div>
                    <div class="stat-card-info">
                        <h6>Upcoming Visits</h6>
                        <h2><%= upcoming_visits %></h2>
                        <span class="text-xxs text-success"><i class="fa-solid fa-circle-check"></i> Active scheduling</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4 stat-card-wrapper">
                <div class="stat-card">
                    <div class="stat-icon warning">
                        <i class="fa-solid fa-users text-warning"></i>
                    </div>
                    <div class="stat-card-info">
                        <h6>Student Impact</h6>
                        <h2><%= total_students %></h2>
                        <span class="text-xxs text-primary"><i class="fa-solid fa-graduation-cap"></i> Total students reached</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Panel split side-by-side: Left=Upcoming Engagements, Right=Engagement Trend -->
        <div class="row g-4">
            <!-- Left Side: Upcoming Engagements -->
            <div class="col-lg-7">
                <div class="panel-card h-100 mb-0">
                    <div class="panel-card-header">
                        <h5>Upcoming Engagements</h5>
                        <span class="text-muted text-xs">Visits in progress or scheduled</span>
                    </div>
                    <div class="panel-card-body p-0">
                        <div class="table-responsive">
                            <table class="table custom-table align-middle">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Company</th>
                                        <th>Type</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% 
                                    // Filter engagements that are scheduled or pending approval
                                    const upcoming = engagements.filter(e => e.status === 'Scheduled' || e.status === 'Pending Approval').slice(0, 5);
                                    if (upcoming.length > 0) { 
                                        upcoming.forEach(row => { 
                                    %>
                                        <tr>
                                            <td><span class="fw-medium text-dark"><%= row.date_occurred %></span></td>
                                            <td><strong><%= row.company_name %></strong></td>
                                            <td>
                                                <span class="badge bg-light text-secondary border rounded-pill px-2 py-1" style="font-size: 0.75rem;">
                                                    <%= row.engagement_type %>
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                <div class="d-flex justify-content-end gap-1">
                                                    <% if (user && user.role === 'Admin') { %>
                                                        <a href="/visits/approvals?id=<%= row.id %>" class="btn btn-outline-primary btn-sm py-1 px-2 text-xxs d-flex align-items-center">
                                                            Pipeline
                                                        </a>
                                                    <% } %>
                                                    <form method="POST" action="/visits/complete" class="m-0" onsubmit="return confirm('Are you sure you want to update this visit status to Completed?')">
                                                        <input type="hidden" name="id" value="<%= row.id %>">
                                                        <button type="submit" class="btn btn-success btn-sm py-1 px-2 text-xxs d-flex align-items-center gap-1">
                                                            <i class="fa-solid fa-circle-check"></i> Complete
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% 
                                        }); 
                                    } else { 
                                    %>
                                        <tr>
                                            <td colspan="4" class="text-center py-4 text-muted">No upcoming engagements scheduled.</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Engagement Trend Chart -->
            <div class="col-lg-5">
                <div class="panel-card h-100 mb-0">
                    <div class="panel-card-header">
                        <h5>Engagement Trend (This Year)</h5>
                    </div>
                    <div class="panel-card-body d-flex flex-column justify-content-center" style="min-height: 250px;">
                        <div class="relative" style="height: 200px; position: relative;">
                            <canvas id="trendChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Chart Script for Dashboard -->
<script>
document.addEventListener("DOMContentLoaded", function() {
    const ctx = document.getElementById('trendChart').getContext('2d');
    
    // Mock months trend data matching standard display
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
            datasets: [{
                label: 'Engagements',
                data: [120, 240, 480, 550, 400, 600],
                backgroundColor: '#3b82f6',
                hoverBackgroundColor: '#2563eb',
                borderRadius: 6,
                barPercentage: 0.55
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { borderDash: [2, 4], color: '#f1f5f9' },
                    border: { display: false },
                    ticks: { font: { size: 9 }, color: '#94a3b8', stepSize: 200 }
                },
                x: {
                    grid: { display: false },
                    border: { display: false },
                    ticks: { font: { size: 9 }, color: '#94a3b8' }
                }
            }
        }
    });
});
</script>

<%- include('partials/footer') %>
